{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@softwarity/draw-adapter": ["../draw-adapter/dist/index", "./node_modules/@softwarity/draw-adapter/dist/index"],
      "@softwarity/draw-adapter/maplibre": ["../draw-adapter/dist/maplibre", "./node_modules/@softwarity/draw-adapter/dist/maplibre"],
      "@softwarity/draw-adapter/openlayers": ["../draw-adapter/dist/openlayers", "./node_modules/@softwarity/draw-adapter/dist/openlayers"],
      "@softwarity/draw-adapter/leaflet": ["../draw-adapter/dist/leaflet", "./node_modules/@softwarity/draw-adapter/dist/leaflet"]
    }
  },
  "include": ["src"]
}
