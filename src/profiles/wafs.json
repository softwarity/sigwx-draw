{
  "schemaVersion": 1,
  "id": "wafs",
  "vertical": {
    "min": 250,
    "max": 600,
    "unit": "fl"
  },
  "callouts": {
    "minZoneFraction": 0.15
  },
  "areas": [
    { "id": "A",  "name": "Eastern Pacific & Americas",          "extent": [-137.4, -54, -12.6, 67],    "projection": { "kind": "mercator" }, "verified": true },
    { "id": "B",  "name": "EUR/SAM — Europe to South America",    "extent": [-100, -60, 30, 65],         "projection": { "kind": "mercator" }, "verified": false },
    { "id": "B1", "name": "EUR/SAM B1 — Atlantic & Americas",     "extent": [-140, -60, 40, 70],         "projection": { "kind": "mercator" }, "verified": false },
    { "id": "C",  "name": "EUR/AFI — Europe to Africa",           "extent": [-45, -50, 60, 72],          "projection": { "kind": "mercator" }, "verified": false },
    { "id": "D",  "name": "Africa, Asia & Southern Europe",       "extent": [-15, -27, 132, 63],         "projection": { "kind": "mercator" }, "verified": true },
    { "id": "E",  "name": "Indian Ocean & Asia",                  "extent": [24.77, -53.92, 180, 44.92], "projection": { "kind": "mercator" }, "verified": true },
    { "id": "F",  "name": "South-West Pacific",                   "extent": [100, -47.5, -110, 42.5],    "projection": { "kind": "mercator" }, "verified": true },
    { "id": "M",  "name": "North Pacific",                        "extent": [110, -10, -110, 72],        "projection": { "kind": "mercator" }, "verified": true },
    { "id": "G",  "name": "Northern Hemisphere — Europe & Asia",  "extent": [-30, 10, 150, 90],          "projection": { "kind": "stereographic", "pole": "north", "code": "EPSG:3995", "def": "+proj=stere +lat_0=90 +lat_ts=71 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs" }, "verified": false },
    { "id": "H",  "name": "NAT — North Atlantic",                 "extent": [-90, 0, 30, 90],            "projection": { "kind": "stereographic", "pole": "north", "code": "EPSG:3995", "def": "+proj=stere +lat_0=90 +lat_ts=71 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs" }, "verified": false },
    { "id": "I",  "name": "NPAC — North Pacific",                 "extent": [120, 0, -120, 90],          "projection": { "kind": "stereographic", "pole": "north", "code": "EPSG:3995", "def": "+proj=stere +lat_0=90 +lat_ts=71 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs" }, "verified": false },
    { "id": "J",  "name": "Southern Hemisphere — S. Pacific & Antarctica", "extent": [-180, -90, -60, 10], "projection": { "kind": "stereographic", "pole": "south", "code": "EPSG:3031", "def": "+proj=stere +lat_0=-90 +lat_ts=-71 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs" }, "verified": false },
    { "id": "K",  "name": "Southern Hemisphere — S. Indian & Southern Ocean", "extent": [20, -90, 160, 10], "projection": { "kind": "stereographic", "pole": "south", "code": "EPSG:3031", "def": "+proj=stere +lat_0=-90 +lat_ts=-71 +lon_0=0 +x_0=0 +y_0=0 +datum=WGS84 +units=m +no_defs" }, "verified": false }
  ],
  "objects": [
    {
      "schemaVersion": 1,
      "type": "jetStream",
      "label": "Jet stream",
      "gesture": {
        "primitive": "polyline",
        "draw": "lasso",
        "smooth": true,
        "directional": true,
        "minVertices": 2
      },
      "fields": [
        {
          "key": "points",
          "kind": "list",
          "label": "Break points",
          "itemLabel": "#{#} · {speed|round}KT",
          "default": [
            {
              "t": 0,
              "speed": 80,
              "fl": 300
            },
            {
              "t": 0.5,
              "speed": 80,
              "fl": 300
            },
            {
              "t": 1,
              "speed": 80,
              "fl": 300
            }
          ],
          "item": [
            {
              "key": "speed",
              "kind": "number",
              "label": "Speed",
              "unit": "kt",
              "min": 80,
              "max": 250,
              "step": 5,
              "default": 100
            },
            {
              "key": "fl",
              "kind": "fl",
              "label": "Flight level",
              "default": 300
            },
            {
              "key": "top",
              "kind": "fl",
              "label": "Extent top",
              "default": 340,
              "when": {
                "field": "speed",
                "gte": 120
              }
            },
            {
              "key": "base",
              "kind": "fl",
              "label": "Extent base",
              "default": 260,
              "when": {
                "field": "speed",
                "gte": 120
              }
            }
          ]
        }
      ],
      "render": {
        "decorations": [
          {
            "use": "jet-barbs",
            "listField": "points",
            "floor": 80,
            "depthAt": 120
          }
        ]
      },
      "satellites": [
        {
          "part": "dial",
          "anchor": "break-point",
          "side": "center",
          "items": [
            {
              "dial": {
                "field": "speed"
              }
            }
          ]
        },
        {
          "part": "gauge",
          "anchor": "break-point",
          "pin": "flRef",
          "side": "right",
          "items": [
            {
              "gauge": {
                "cursors": [
                  "fl"
                ],
                "extent": [
                  "base",
                  "top"
                ]
              }
            }
          ]
        }
      ],
      "style": {
        "color": "#1f2328",
        "arrow": {
          "color": "#1f2328",
          "width": 3
        },
        "text": {
          "color": "#1f2328",
          "halo": "#ffffff",
          "size": 13
        }
      },
      "summary": "Jet max {points|maxof:speed}KT",
      "declutter": {
        "chrome": true,
        "late": [
          "arrowhead"
        ]
      }
    },
    {
      "schemaVersion": 1,
      "type": "cb",
      "label": "Cumulonimbus (CB)",
      "gesture": {
        "primitive": "polygon",
        "draw": "lasso",
        "smooth": true,
        "multiArea": true,
        "erasable": true,
        "default": "regular-polygon"
      },
      "fields": [
        {
          "key": "coverage",
          "kind": "enum",
          "label": "Coverage",
          "options": [
            {
              "value": "OCNL",
              "label": "OCNL — occasional (50–75%)",
              "meta": {
                "bufr": 10
              }
            },
            {
              "value": "FRQ",
              "label": "FRQ — frequent (>75%)",
              "meta": {
                "bufr": 12
              }
            }
          ]
        },
        {
          "key": "baseFL",
          "kind": "fl",
          "label": "Base",
          "default": 250
        },
        {
          "key": "topFL",
          "kind": "fl",
          "label": "Top",
          "default": 400
        }
      ],
      "flBeyond": [
        "xxx",
        "xxx"
      ],
      "render": {
        "edge": {
          "treatment": "scallop",
          "width": 2
        },
        "fill": {
          "opacity": 0.12
        },
        "callout": {
          "anchor": "largest-area-centroid",
          "leader": "lightning",
          "arrow": true,
          "box": true,
          "content": [
            "{coverage|stack}",
            "CB",
            "{topFL|flx:top}",
            "{baseFL|flx:base}"
          ]
        }
      },
      "card": {
        "framed": true,
        "items": [
          {
            "carousel": {
              "field": "coverage",
              "label": "{value|stack}\nCB"
            }
          },
          {
            "text": "{topFL|flx:top}"
          },
          {
            "text": "{baseFL|flx:base}"
          }
        ],
        "buttons": [
          {
            "place": "anchor",
            "action": "draw_and_link",
            "svg": "atlas:draw",
            "title": "Draw a linked area"
          }
        ]
      },
      "satellites": [
        {
          "part": "gauge",
          "anchor": "callout",
          "pin": "flRef",
          "side": "right",
          "items": [
            {
              "gauge": {
                "cursors": [
                  "baseFL",
                  "topFL"
                ]
              }
            }
          ]
        }
      ],
      "style": {
        "color": "#d1242f",
        "edge": {
          "color": "#d1242f",
          "width": 2,
          "decorator": "scallop"
        },
        "area": {
          "color": "#d1242f",
          "opacity": 0.12
        },
        "symbol": {
          "sprite": "OCNL",
          "size": 1
        },
        "text": {
          "halo": "#ffffff",
          "size": 13
        }
      },
      "summary": "{coverage} CB {topFL|fl}/{baseFL|fl}"
    },
    {
      "schemaVersion": 1,
      "type": "icing",
      "label": "Icing",
      "gesture": {
        "primitive": "polygon",
        "draw": "lasso",
        "smooth": true,
        "multiArea": true,
        "erasable": true,
        "default": "regular-polygon"
      },
      "fields": [
        {
          "key": "symbol",
          "kind": "enum",
          "label": "Intensity",
          "options": [
            {
              "value": "ICE_MOD",
              "label": "MOD — moderate"
            },
            {
              "value": "ICE_SEV",
              "label": "SEV — severe"
            }
          ]
        },
        {
          "key": "baseFL",
          "kind": "fl",
          "label": "Base",
          "default": 250
        },
        {
          "key": "topFL",
          "kind": "fl",
          "label": "Top",
          "default": 360
        }
      ],
      "flBeyond": [
        "xxx",
        "xxx"
      ],
      "render": {
        "edge": {
          "treatment": "ticks",
          "width": 2.5,
          "dash": [
            4,
            2
          ]
        },
        "fill": {
          "opacity": 0.18
        },
        "ink": {
          "byField": "symbol",
          "map": {
            "ICE_SEV": "sev",
            "*": "mod"
          }
        },
        "callout": {
          "anchor": "largest-area-centroid",
          "leader": "lightning",
          "arrow": true,
          "box": true,
          "symbol": {
            "byField": "symbol",
            "inside": true
          },
          "content": [
            "{topFL|flx:top}",
            "{baseFL|flx:base}"
          ]
        }
      },
      "card": {
        "framed": true,
        "items": [
          {
            "carousel": {
              "field": "symbol"
            }
          },
          {
            "text": "{topFL|flx:top}"
          },
          {
            "text": "{baseFL|flx:base}"
          }
        ],
        "buttons": [
          {
            "place": "anchor",
            "action": "draw_and_link",
            "svg": "atlas:draw",
            "title": "Draw a linked area"
          }
        ]
      },
      "satellites": [
        {
          "part": "gauge",
          "anchor": "callout",
          "pin": "flRef",
          "side": "right",
          "items": [
            {
              "gauge": {
                "cursors": [
                  "baseFL",
                  "topFL"
                ]
              }
            }
          ]
        }
      ],
      "style": {
        "color": "#8250df",
        "mod": {
          "color": "#a371f7"
        },
        "sev": {
          "color": "#6639ba"
        },
        "edge": {
          "width": 2.5,
          "dash": [
            4,
            2
          ],
          "decorator": "dashed"
        },
        "area": {
          "opacity": 0.18
        },
        "symbol": {
          "sprite": "ICE_MOD",
          "size": 1
        },
        "text": {
          "halo": "#ffffff",
          "size": 13
        }
      },
      "summary": "{symbol|strip:ICE_} ICE {topFL|fl}/{baseFL|fl}"
    },
    {
      "schemaVersion": 1,
      "type": "turbulence",
      "label": "Turbulence",
      "gesture": {
        "primitive": "polygon",
        "draw": "lasso",
        "smooth": true,
        "multiArea": true,
        "erasable": true,
        "default": "regular-polygon"
      },
      "fields": [
        {
          "key": "symbol",
          "kind": "enum",
          "label": "Symbol",
          "options": [
            {
              "value": "MOD",
              "label": "MOD — moderate"
            },
            {
              "value": "SEV",
              "label": "SEV — severe"
            }
          ]
        },
        {
          "key": "baseFL",
          "kind": "fl",
          "label": "Base",
          "default": 250
        },
        {
          "key": "topFL",
          "kind": "fl",
          "label": "Top",
          "default": 360
        }
      ],
      "flBeyond": [
        "xxx",
        "xxx"
      ],
      "render": {
        "edge": {
          "treatment": "dash",
