      "fields": [
        {
          "key": "name",
          "kind": "text",
          "label": "Name",
          "default": ""
        }
      ],
      "card": {
        "framed": "when-named",
        "deletable": true,
        "items": [
          {
            "glyph": "atlas:radioactive",
            "size": 26
          },
          {
            "input": {
              "field": "name"
            }
          },
          {
            "coord": true
          }
        ]
      },
      "style": {
        "color": "#1f2328"
      }
    }
  ],
  "tools": [
    "jetStream",
    "cb",
    "icing",
    "turbulence",
    "tropopause",
    {
      "group": "Markers",
      "items": [
        "volcano",
        "tropicalCyclone",
        "radioactive"
      ]
    }
  ],
  "glyphs": {
    "cb": "buttons/cb.svg",
    "draw": "buttons/draw.svg",
    "icing": "buttons/icing.svg",
    "jetStream": "buttons/jetStream.svg",
    "radioactive": "buttons/radioactive.svg",
    "tc-nh": "buttons/tc-nh.svg",
    "tc-sh": "buttons/tc-sh.svg",
    "tropopause": "buttons/tropopause.svg",
