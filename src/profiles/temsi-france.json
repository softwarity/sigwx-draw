{
  "schemaVersion": 1,
  "id": "temsi-france",
  "vertical": {
    "min": 0,
    "max": 150,
    "unit": "fl"
  },
  "callouts": {
    "minZoneFraction": 0.15
  },
  "objects": [
    {
      "schemaVersion": 1,
      "type": "zeroIsotherm",
      "label": "Isotherme",
      "gesture": {
        "primitive": "polyline",
        "draw": "lasso-or-spot",
        "smooth": true,
        "minVertices": 2
      },
      "fields": [
        {
          "key": "temp",
          "kind": "enum",
          "label": "Température",
          "default": "0",
          "options": [
            { "value": "0", "label": "0 °C" },
            { "value": "−10", "label": "−10 °C" }
          ]
        },
        {
          "key": "fl",
          "kind": "fl",
          "label": "Niveau",
          "default": 100
        }
      ],
      "render": {
        "line": {
          "edge": {
            "treatment": "plain",
            "width": 2
          },
          "label": {
            "anchor": "geometry-mid",
            "content": [
              "{temp}°: {fl}"
            ],
            "box": true,
            "movable": true,
            "borderWidth": "small"
          }
        },
        "point": {
          "label": {
            "anchor": "geometry-mid",
            "content": [
              "{temp}°: {fl}"
            ],
            "box": true,
            "borderWidth": "small"
          }
        }
      },
      "satellites": [
        {
          "part": "gauge",
          "anchor": "geometry-mid",
          "pin": "flRef",
          "side": "right",
          "items": [
            {
              "picker": {
                "field": "temp",
                "label": "{value} °C"
              }
            },
            {
              "gauge": {
                "cursors": [
                  "fl"
                ]
              }
            }
          ]
        }
      ],
      "style": {
        "color": "#0b6bcb",
        "edge": {
          "color": "#0b6bcb",
          "width": 2
        },
        "text": {
          "color": "#0b6bcb",
          "halo": "#ffffff",
          "size": 12,
          "background": "transparent"
        }
      },
      "summary": "{temp}°C {fl|fl}"
    },
    {
      "schemaVersion": 1,
      "type": "pressureCentre",
      "label": "Centre de pression",
      "gesture": {
        "primitive": "point",
        "draw": "drop"
      },
      "fields": [
        {
          "key": "kind",
          "kind": "enum",
          "label": "Type",
          "default": "A",
          "options": [
            {
              "value": "A",
              "label": "Anticyclone (A)"
            },
            {
              "value": "D",
              "label": "Dépression (D)"
            }
          ]
        },
        {
          "key": "pressure",
          "kind": "text",
          "label": "Pression (hPa)",
          "default": "1013"
        }
      ],
      "card": {
        "framed": "when-named",
        "origin": "bottom",
        "deletable": true,
        "items": [
          {
            "picker": {
              "field": "kind"
            },
            "size": 24
          },
          {
            "input": {
              "field": "pressure"
            }
          },
          {
            "coord": true
          }
        ]
      },
      "style": {
        "color": "#1f2328",
        "text": {
          "color": "#1f2328"
        }
      },
      "summary": "{kind} {pressure} hPa"
    },
    {
      "schemaVersion": 1,
      "type": "cloudConvective",
