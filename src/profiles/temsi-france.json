              "default": "OCNL",
              "options": [
                { "value": "ISOL", "label": "ISOL — CB isolés" },
                { "value": "OCNL", "label": "OCNL — CB bien séparés" },
                { "value": "FRQ", "label": "FRQ — CB peu/pas séparés" },
                { "value": "EMBD", "label": "EMBD — CB noyés" }
              ],
              "optionsBy": {
                "field": "type",
                "map": {
                  "CB": [
                    { "value": "ISOL", "label": "ISOL — CB isolés" },
                    { "value": "OCNL", "label": "OCNL — CB bien séparés" },
                    { "value": "FRQ", "label": "FRQ — CB peu/pas séparés" },
                    { "value": "EMBD", "label": "EMBD — CB noyés" }
                  ],
                  "*": [
                    { "value": "FEW", "label": "FEW — 1-2/8" },
                    { "value": "SCT", "label": "SCT — 3-4/8" },
                    { "value": "BKN", "label": "BKN — 5-7/8" },
                    { "value": "OVC", "label": "OVC — 8/8" }
                  ]
                }
              }
            },
            {
              "key": "baseFL",
              "kind": "fl",
              "label": "Base",
              "default": 25
            },
            {
              "key": "topFL",
              "kind": "fl",
              "label": "Top",
              "default": 155
            }
          ]
        }
      ],
      "flBeyond": [
        "xxx",
        "xxx"
      ],
      "render": {
        "edge": {
          "treatment": "scallop",
          "width": 2
        },
        "fill": {
          "opacity": 0.12
        },
        "callout": {
          "anchor": "largest-area-centroid",
          "leader": "lightning",
          "arrow": true,
          "box": true,
          "content": [
            "{amount} {type} {baseFL|flx:base}/{topFL|flx:top}"
          ],
          "contentSingle": [
            "{amount}",
            "{type}",
            "{topFL|flx:top}",
            "{baseFL|flx:base}"
          ]
        }
      },
      "card": {
        "framed": true,
        "pad": "large",
        "origin": "bottom",
        "gap": 2,
        "items": [
          {
            "picker": {
              "field": "amount",
              "label": "{value}"
            }
          },
          {
            "picker": {
              "field": "type",
              "label": "{value}"
            }
