{
  "name": "@softwarity/sigwx-draw",
  "version": "0.3.0",
  "description": "Draw SIGWX (significant weather) charts on any map (grafts onto MapLibre, OpenLayers or Leaflet, Terra-Draw-style). Phenomenon-driven geometry whose metadata controls the rendering (jet barbs, scalloped CB, dashed turbulence, …).",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./maplibre": {
      "types": "./dist/map/maplibre-adapter.d.ts",
      "import": "./dist/map/maplibre-adapter.js"
    },
    "./openlayers": {
      "types": "./dist/map/openlayers-adapter.d.ts",
      "import": "./dist/map/openlayers-adapter.js"
    },
    "./leaflet": {
      "types": "./dist/map/leaflet-adapter.d.ts",
      "import": "./dist/map/leaflet-adapter.js"
    },
    "./form": {
      "types": "./dist/form/index.d.ts",
      "import": "./dist/form/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@softwarity/draw-adapter": "^0.2.9",
    "@types/geojson": "^7946.0.14"
  },
  "peerDependencies": {
    "leaflet": ">=1.9",
    "maplibre-gl": ">=5",
    "ol": ">=9"
  },
  "peerDependenciesMeta": {
    "leaflet": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    },
    "ol": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "jsdom": "^29.1.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.24.0",
    "ol": "^10.9.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
